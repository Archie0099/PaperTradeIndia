# ---------------------------------------------------------------------------
# Copy this file to ".env" and tweak if you like. All values have safe
# defaults, so the app runs even with NO .env file at all.
# ---------------------------------------------------------------------------

# Port the web server listens on. Open http://localhost:PORT in your browser.
PORT=3000

# (The option-pricing risk-free rate is a CLIENT setting — change it live in the
# UI — so there is no server-side env var for it.)

# How long (in milliseconds) to cache market data so we stay within the
# free data sources' rate limits. NSE asks for ~1 request / 3 seconds.
QUOTE_CACHE_MS=4000
CHAIN_CACHE_MS=4000
HISTORY_CACHE_MS=60000

# Browser-like User-Agent. Yahoo and NSE block obvious bots, so we pretend
# to be a normal desktop browser. You normally never need to change this.
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36
